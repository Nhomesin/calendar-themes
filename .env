# ─────────────────────────────────────────
#  CalTheme — Environment Variables
#  Copy this to .env and fill in your values
#  NEVER commit .env to git
# ─────────────────────────────────────────

# GHL OAuth credentials (from Marketplace portal after app creation)
GHL_CLIENT_ID=your_client_id_here
GHL_CLIENT_SECRET=your_client_secret_here

# The redirect URI you registered in GHL — must match exactly
GHL_REDIRECT_URI=https://your-railway-app.up.railway.app/oauth/callback

# Your app's public base URL (no trailing slash)
APP_BASE_URL=https://your-railway-app.up.railway.app

# GHL API base
GHL_API_BASE=https://services.leadconnectorhq.com

# GHL OAuth base
GHL_AUTH_BASE=https://marketplace.gohighlevel.com

# Session / signing secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_random_32_byte_hex

# Port (Railway sets this automatically — leave as 3000 for local)
PORT=3000
