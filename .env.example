# ─────────────────────────────────────────
#  CalTheme — Environment Variables
#  Copy this to .env and fill in your values
#  NEVER commit .env to git
# ─────────────────────────────────────────

# GHL OAuth credentials (from Marketplace portal after app creation)
GHL_CLIENT_ID=your_client_id_here
GHL_CLIENT_SECRET=your_client_secret_here

# The redirect URI you registered in GHL — must match exactly
GHL_REDIRECT_URI=https://your-railway-app.up.railway.app/oauth/callback

# Your app's public base URL (no trailing slash)
APP_BASE_URL=https://your-railway-app.up.railway.app

# Session / signing secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_random_32_byte_hex

# Port (Railway sets this automatically — leave as 3000 for local)
PORT=3000

# Supabase — hosted Postgres (Project Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Paddle (Merchant of Record) billing
# PADDLE_ENVIRONMENT selects the SDK target: "sandbox" or "production".
# Swap the *_API_KEY / *_WEBHOOK_SECRET / *_PRICE_* values per environment.
PADDLE_ENVIRONMENT=sandbox
PADDLE_API_KEY=your_paddle_api_key
PADDLE_CLIENT_TOKEN=your_paddle_client_token
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret
PADDLE_WEBHOOK_URL=https://your-railway-app.up.railway.app/webhooks/paddle

# Paddle price IDs — create these in the Paddle dashboard (Catalog → Prices)
PADDLE_PRICE_SUBACCOUNT_MONTHLY=pri_xxx_subaccount_monthly
PADDLE_PRICE_SUBACCOUNT_YEARLY=pri_xxx_subaccount_yearly
PADDLE_PRICE_AGENCY_MONTHLY=pri_xxx_agency_monthly
PADDLE_PRICE_AGENCY_YEARLY=pri_xxx_agency_yearly
